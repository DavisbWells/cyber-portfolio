# ============================================================
# .gitignore — Cyber Operations Portfolio
# ============================================================

# ⚠ SECURITY: If you add a real GITHUB_TOKEN to config.js, add it back here.
# With an empty token (the default), config.js is safe to commit.
# config.js
*.key
*.pem
*.p12
*.pfx
.env
.env.local
.env.*.local

# Node.js (if build tools are added later)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyc
venv/
env/
.venv/

# IDE
.vscode/settings.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# OS artifacts
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Build & distribution
dist/
build/
*.min.js
*.min.css

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.bak
